% neurips_style.sty
% Estilo leve que emula a aparência do template NeurIPS, autocontido para
% compilar com tectonic/pdflatex sem depender do .sty oficial (que não é
% redistribuído no CTAN). Caso deseje o template oficial, basta substituir
% \usepackage{neurips_style} por \usepackage{neurips_2024} e adicionar o .sty.
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{neurips_style}[2024/01/01 Estilo NeurIPS-like autocontido]

\RequirePackage[letterpaper,margin=1in,top=1in,bottom=1in]{geometry}
\RequirePackage{times}
\RequirePackage{microtype}
\RequirePackage{titlesec}

% Espaçamento de parágrafos
\setlength{\parindent}{0pt}
\setlength{\parskip}{0.6em}

% Títulos de seção em estilo NeurIPS (caixa baixa, negrito, numerados)
\titleformat{\section}{\large\bfseries}{\thesection}{0.6em}{}
\titleformat{\subsection}{\normalsize\bfseries}{\thesubsection}{0.6em}{}
\titlespacing*{\section}{0pt}{1.2em}{0.4em}
\titlespacing*{\subsection}{0pt}{0.9em}{0.3em}

% Comando de título compacto (título + autores + data centralizados)
\renewcommand{\maketitle}{%
  \begin{center}
    {\LARGE\bfseries \@title \par}
    \vskip 1em
    {\large \@author \par}
    \vskip 0.5em
    {\normalsize \@date \par}
  \end{center}
  \vskip 1.0em
}

% Abstract mais estreito, como no NeurIPS
\renewenvironment{abstract}{%
  \centerline{\bfseries Resumo}\vspace{0.4em}%
  \begin{quote}\small%
}{%
  \end{quote}\vspace{0.6em}%
}
